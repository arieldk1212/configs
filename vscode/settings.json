{
    "files.autoSave": "afterDelay",
    "editor.tabSize": 2,
    "editor.fontSize": 15,
    "editor.renderWhitespace": "all",
    "workbench.colorCustomizations": {
    // "statusBar.background": "#41033d", // General background color
    // "activityBar.background": "#451861",
    // "titleBar.activeBackground": "#451861",
    },
    // space mono, sf mono, Jetbrans Mono, cascadia mono, Menlo
    // "editor.fontFamily": "fira code",
    "terminal.integrated.fontSize": 17,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "workbench.startupEditor": "none",
    "workbench.settings.applyToAllProfiles": ["files.autoSave"],
    "extensions.ignoreRecommendations": true,

    "git.openRepositoryInParentFolders": "never",

    "clangd.arguments": ["--compile-commands-dir=${workspaceFolder}/build"], // in cmake -> set(CMAKE_EXPORT_COMPILE_COMMANDS ON)

    "editor.wordBasedSuggestions": "off",
    "editor.stickyScroll.defaultModel": "foldingProviderModel",
    "editor.suggest.insertMode": "replace",
    "editor.defaultFormatter": "xaver.clang-format",
    "lldb.suppressUpdateNotifications": true,
    "lldb.showDisassembly": "never",
    "[cmake]": {
        "editor.defaultFormatter": "cheshirekow.cmake-format"
    },
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "editor.fontLigatures": true,
    "chat.viewSessions.orientation": "stacked",
    "diffEditor.codeLens": true,
    "editor.formatOnSave": true,
    "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/env": true,
    "**/venv": true
  },
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/env/**": true,
        "**/venv/**": true,
        "env-*": true
    },
    "telemetry.feedback.enabled": false,
    "telemetry.telemetryLevel": "off",
    "telemetry.editStats.enabled": false,
    "editor.bracketPairColorization.enabled": false,
    "[markdown]": {
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
    },
    "python.analysis.typeCheckingMode": "standard",
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "workbench.colorTheme": "Dark Modern",
    "clangd.detectExtensionConflicts": false,
    "[cuda-cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    "[starlark]": {
        "editor.defaultFormatter": "BazelBuild.vscode-bazel"
    },
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer",
        "editor.formatOnSave": true
    
    },
}